# ============================================================
#  Environment variables
#  Copy this file to .env for local development.
#  .env is git-ignored and must never be committed.
# ============================================================

# The public Stripe Payment Link that the booking button opens.
# Create it in the Stripe Dashboard under Payments → Payment Links.
# This value is PUBLIC and is bundled into the frontend build — only ever
# put the Payment Link here. Never a secret key (sk_live_… / sk_test_…),
# and never a restricted key.
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/8x2dR9cblfm8awe7kj5wI03
